{
  "name": "plx",
  "version": "0.1.0",
  "description": "Natural-language shell assistant — turn plain English into safe, confirmable POSIX commands, with an optional multi-step agent mode.",
  "license": "MIT",
  "type": "module",
  "module": "src/index.ts",
  "private": true,
  "keywords": [
    "cli",
    "shell",
    "ai",
    "agent",
    "llm",
    "terminal",
    "bun",
    "vercel-ai-sdk"
  ],
  "bin": {
    "plx": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile plx",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "ai": "^6",
    "chalk": "^5",
    "commander": "^14",
    "execa": "^9",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
