# ── Vercel AI Gateway credentials ──────────────────────────────────────────────
# A static API key from the Vercel dashboard → AI Gateway.  Docs: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# This .env only applies when you run plx *from this directory*. To use plx from
# anywhere (recommended), put the same line in your user-global config instead:
#     mkdir -p ~/.config/plx && $EDITOR ~/.config/plx/.env      # AI_GATEWAY_API_KEY=...
# …or just export it in your shell rc (~/.zshrc / ~/.bashrc, or `set -gx` in fish).
#
# Alternative (auto-rotating, no manual key): inside a linked Vercel project run
#   vercel env pull .env.local
# which provisions VERCEL_OIDC_TOKEN; the AI Gateway uses it when AI_GATEWAY_API_KEY is unset.

# ── Optional ───────────────────────────────────────────────────────────────────
# Override the default model. Any AI Gateway "provider/model" id.
# The --model flag takes precedence over this. Default: deepseek/deepseek-v4-flash
# PLX_MODEL=deepseek/deepseek-v4-flash
